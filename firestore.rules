rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Client Validation
    function isValidClient(data) {
      return data.id is string
        && data.name is string && data.name.size() <= 300
        && data.companyName is string && data.companyName.size() <= 300;
    }

    // Employee Validation
    function isValidEmployee(data) {
      return data.id is string 
        && data.name is string && data.name.size() <= 300
        && data.role is string && data.role.size() <= 200
        && data.email is string && data.email.size() <= 200;
    }

    match /test/connection {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/clients/{clientId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(clientId) && isValidClient(incoming());
      allow update: if isOwner(userId) && isValidId(clientId) && isValidClient(incoming())
                    && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'companyName', 'cnpj', 'email', 'phone']));
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/employees/{employeeId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(employeeId) && isValidEmployee(incoming());
      allow update: if isOwner(userId) && isValidId(employeeId) && isValidEmployee(incoming())
                    && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'email', 'phone']));
      allow delete: if isOwner(userId);
    }

    // Project Validation
    function isValidProject(data) {
      return data.id is string
        && data.name is string && data.name.size() <= 300
        && (data.get('assignedEmployeeIds', []) is list);
    }

    match /users/{userId}/projects/{projectId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(projectId) && isValidProject(incoming());
      allow update: if isOwner(userId) && isValidId(projectId) && isValidProject(incoming())
                    && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'totalValue', 'status', 'deadline', 'stage', 'assignedEmployeeIds', 'installments']));
      allow delete: if isOwner(userId);
    }
  }
}
